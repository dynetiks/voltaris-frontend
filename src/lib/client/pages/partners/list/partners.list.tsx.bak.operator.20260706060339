                    <TableCell>{alert.time}</TableCell>
                    <TableCell>{alert.source}</TableCell>
                    <TableCell>{alert.signal}</TableCell>
                    <TableCell>{alert.severity}</TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </DataTable>
          </div>
        </div>
      </div>
    </div>
  );

  const stationDashboard = (
    <div className="flex min-w-0 flex-col gap-5">
      <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {stationMetrics.map((metric) => (
          <div
            key={metric.label}
            className="rounded-md border border-border bg-card p-5 shadow-sm"
          >
            <p className="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground">
              {metric.label}
            </p>
            <p className="mt-2 text-3xl font-semibold text-foreground">
              {metric.value}
            </p>
            <p className="mt-1 text-sm text-muted-foreground">
              {metric.detail}
            </p>
          </div>
        ))}
      </div>

      <div className="grid gap-5 xl:grid-cols-[1.25fr_0.75fr]">
        <div className="rounded-md border border-border bg-card p-5 shadow-sm">
          <div className="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h2 className={heading2Style}>Station Dashboard</h2>
              <p className="mt-1 text-sm text-muted-foreground">
                Live device-level view for PK-KHI-DC-018: load, connector
                state, active session, and local diagnostics.
              </p>
            </div>
            <div className="rounded-md border border-green-200 bg-green-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-green-700">
              Online
            </div>
          </div>
          <ChartContainer
            config={stationLoadChartConfig}
            className="mt-4 h-72 w-full"
          >
            <LineChart data={stationLoadSeries} margin={{ left: 12, right: 12 }}>
              <CartesianGrid vertical={false} />
              <XAxis dataKey="time" tickLine={false} axisLine={false} />
              <YAxis tickLine={false} axisLine={false} />
              <ChartTooltip content={<ChartTooltipContent />} />
              <Line
                type="monotone"
                dataKey="power"
                stroke="var(--color-power)"
                strokeWidth={2}
                dot={false}
              />
              <Line
                type="monotone"
                dataKey="temperature"
                stroke="var(--color-temperature)"
                strokeWidth={2}
                dot={false}
              />
              <Line
                type="monotone"
                dataKey="sessions"
                stroke="var(--color-sessions)"
                strokeWidth={2}
                dot={false}
              />
            </LineChart>
          </ChartContainer>
        </div>

        <div className="rounded-md border border-border bg-card p-5 shadow-sm">
          <h2 className={heading2Style}>Connector State</h2>
          <div className="mt-4 overflow-hidden rounded-md border border-border bg-background">
            <DataTable>
              <TableHeader>
                <TableRow>
                  <TableHead>Connector</TableHead>
                  <TableHead>Status</TableHead>
                  <TableHead>Power</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {stationConnectors.map((connector) => (
                  <TableRow key={connector.connector}>
                    <TableCell>
                      <p className="font-medium">{connector.connector}</p>
                      <p className="text-xs text-muted-foreground">
                        {connector.type}
                      </p>
                    </TableCell>
                    <TableCell>
                      <span
                        className={`rounded-md px-2 py-1 text-xs font-medium ${
                          connector.status === 'Faulted'
                            ? 'bg-red-100 text-red-700'
                            : connector.status === 'Charging'
                              ? 'bg-blue-100 text-blue-700'
                              : 'bg-green-100 text-green-700'
                        }`}
                      >
                        {connector.status}
                      </span>
                    </TableCell>
                    <TableCell>
                      <p>{connector.power}</p>
                      <p className="text-xs text-muted-foreground">
                        {connector.detail}
                      </p>
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </DataTable>
          </div>
        </div>
      </div>

      <div className="grid gap-5 xl:grid-cols-[1.1fr_0.9fr]">
        <div className="rounded-md border border-border bg-card p-5 shadow-sm">
          <h2 className={heading2Style}>Sessions</h2>
          <div className="mt-4 overflow-hidden rounded-md border border-border bg-background">
            <DataTable>
              <TableHeader>
                <TableRow>
                  <TableHead>Time</TableHead>
                  <TableHead>User</TableHead>
                  <TableHead>Connector</TableHead>
                  <TableHead>Energy</TableHead>
                  <TableHead>Status</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {stationSessions.map((session) => (
                  <TableRow key={`${session.time}-${session.connector}`}>
                    <TableCell>{session.time}</TableCell>
                    <TableCell>{session.user}</TableCell>
                    <TableCell>{session.connector}</TableCell>
                    <TableCell>{session.energy}</TableCell>
                    <TableCell>{session.status}</TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </DataTable>
          </div>
        </div>

        <div className="rounded-md border border-border bg-card p-5 shadow-sm">
          <h2 className={heading2Style}>Diagnostics & Config</h2>
          <div className="mt-4 grid gap-3">
            {stationDiagnostics.map(([signal, status, detail]) => (
              <div
                key={signal}
                className="flex items-center justify-between gap-4 rounded-md border border-border bg-background px-4 py-3"
              >
                <div>
                  <p className="font-medium">{signal}</p>
                  <p className="text-sm text-muted-foreground">{detail}</p>
                </div>
                <span
                  className={`shrink-0 rounded-md px-2 py-1 text-xs font-medium ${
                    status === 'View only'
                      ? 'bg-muted text-muted-foreground'
                      : 'bg-green-100 text-green-700'
                  }`}
                >
                  {status}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );

  return (
    <div className={`mb-6 ml-0 mr-6 mt-6 ${tableWrapperStyle}`}>
      <div className="flex flex-col gap-3 border-b border-border pb-5">
        <div className="rounded-md border border-border bg-muted px-5 py-3">
          <div className="flex items-start justify-between gap-4">
            <p className="text-xs font-medium uppercase tracking-[0.24em] text-muted-foreground">
              VOLTARIS Access
            </p>
            <div className="text-right">
              <p className="text-[10px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                Active Area
              </p>
              <p className="mt-0.5 text-sm font-semibold text-foreground">
                {selectedRoleSection.title}
              </p>
            </div>
          </div>
          <div className="mt-2 flex flex-wrap items-center gap-2">
            <h1 className="text-2xl font-semibold text-foreground">
              {selectedRole.title}
            </h1>
            {selectedRoleSection.items.map((item) => (
              <button
                key={item.title}
                type="button"
                onClick={() =>
                  push(
                    `/${MenuSection.PARTNERS}?role=${selectedRole.id}&section=${getSectionSlug(
                      selectedRoleSection.title,
                    )}&action=${getItemSlug(item.title)}`,
                  )
                }
                className={`rounded-md border px-3 py-1.5 text-sm font-medium shadow-sm transition-colors ${
                  selectedActionParam === getItemSlug(item.title)
                    ? 'border-[#26002e] bg-[#26002e] text-white'
                    : 'border-border bg-background text-foreground hover:bg-accent hover:text-accent-foreground'
                }`}
              >
                {item.title}
              </button>
            ))}
          </div>
        </div>
        <div className="flex flex-col gap-4 pt-3">
          <div className="min-w-0 overflow-hidden rounded-md border border-border bg-[#292927] text-white shadow-sm">
            {selectedRole.callout && (
              <div className="border-b border-white/10 bg-[#123510] px-5 py-3 text-sm font-semibold text-green-400">
                {selectedRole.callout}
              </div>
            )}
            {isTariffSection &&
              (showTariffForm ? tariffChangeForm : tariffHistoryList)}
          </div>
        </div>
      </div>
      {isAuditActivity && auditActivityList}
      {isDiagnosticsLogs && diagnosticsLogsList}
      {isEmergencyAccess && emergencyAccessList}
      {isRightsRoles && rightsRolesList}
      {isUserRoles && userRolesList}
      {isOperatorPortal &&
        (isOperatorAnalytics ? operatorAnalyticsDashboard : operatorPortal)}
      {isStationDashboard && stationDashboard}
      {!isTariffSection &&
        !isAuditActivity &&
        !isDiagnosticsLogs &&
        !isEmergencyAccess &&
        !isRightsRoles &&
        !isUserRoles &&
        !isOperatorPortal &&
        !isStationDashboard && (
          <div className="flex min-w-0 flex-col gap-4">
            <div className={tableHeaderWrapperFlex}>
              <h2 className={heading2Style}>Rights & Management</h2>
              <div className={tableSearchFlex}>
                <CanAccess
                  resource={ResourceType.PARTNERS}
                  action={ActionType.CREATE}
                >
                  <Button
                    variant="success"
                    onClick={() => push(`/${MenuSection.PARTNERS}/new`)}
                  >
                    <Plus className={buttonIconSize} />
                    {translate('buttons.add')}{' '}
                    {translate('TenantPartners.TenantPartners')}
                  </Button>
                </CanAccess>
                <CanAccess
                  resource={ResourceType.PARTNERS}
                  action={ActionType.LIST}
                >
                  {columnSelector}
                </CanAccess>
              </div>
            </div>
            <CanAccess
              resource={ResourceType.PARTNERS}
              action={ActionType.LIST}
              fallback={<AccessDeniedFallback />}
            >
              <Table
                refineCoreProps={{
                  resource: ResourceType.PARTNERS,
                  sorters: DEFAULT_SORTERS,
                  meta: {
                    gqlQuery: PARTNERS_LIST_QUERY,
                  },
                  queryOptions: {
                    ...getPlainToInstanceOptions(TenantPartnerClass),
                    select: (data: any) => {
                      return data;
                    },
                  },
                }}
                enableSorting
                enableFilters
                showHeader
                tableStateKey={ResourceType.PARTNERS}
              >
                {renderedVisibleColumns}
              </Table>
            </CanAccess>
          </div>
        )}
    </div>
  );
};
